# Databricks connectivity for local PySpark / Databricks Connect
#
# host and token are read from ~/.dbt/profiles.yml automatically.
# Only set these here to override the dbt profile values.
#
# DATABRICKS_HOST=dbc-e27abc0b-645c.cloud.databricks.com
# DATABRICKS_TOKEN=dapi...

# Required — not in profiles.yml (cluster must be running)
# Find in: Databricks workspace → Compute → <cluster> → URL contains the cluster ID
DATABRICKS_CLUSTER_ID=
