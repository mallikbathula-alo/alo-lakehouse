# PySpark / Databricks Connect
# Copy this file to .env and fill in your values.
#
# DATABRICKS_HOST and DATABRICKS_TOKEN are read automatically from
# ~/.dbt/profiles.yml (lakehouse → local target) — no need to set them here.
#
# Only DATABRICKS_CLUSTER_ID is required:
#   Databricks → Compute → <cluster> → Configuration → Tags → ClusterId
#   Or from the URL: .../clusters/<CLUSTER_ID>

DATABRICKS_CLUSTER_ID=YOUR_CLUSTER_ID
