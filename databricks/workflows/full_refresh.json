{
  "name": "alo-lakehouse-full-refresh",
  "description": "Weekly full refresh of all dbt models",
  "tags": {
    "project": "alo-lakehouse",
    "schedule": "weekly"
  },
  "schedule": {
    "quartz_cron_expression": "0 0 1 ? * SUN",
    "timezone_id": "America/Los_Angeles",
    "pause_status": "UNPAUSED"
  },
  "max_concurrent_runs": 1,
  "timeout_seconds": 14400,
  "email_notifications": {
    "on_failure": ["data-engineering@aloyoga.com"],
    "on_start": ["data-engineering@aloyoga.com"]
  },
  "tasks": [
    {
      "task_key": "full_refresh_bronze",
      "description": "Full refresh all bronze models",
      "job_cluster_key": "full_refresh_cluster",
      "run_if": "ALL_SUCCESS"
    },
    {
      "task_key": "full_refresh_silver",
      "description": "Full refresh all silver models",
      "depends_on": [{"task_key": "full_refresh_bronze"}],
      "job_cluster_key": "full_refresh_cluster",
      "run_if": "ALL_SUCCESS"
    },
    {
      "task_key": "full_refresh_gold",
      "description": "Full refresh all gold models",
      "depends_on": [{"task_key": "full_refresh_silver"}],
      "job_cluster_key": "full_refresh_cluster",
      "run_if": "ALL_SUCCESS"
    },
    {
      "task_key": "dbt_tests_post_refresh",
      "description": "Full test suite after refresh",
      "depends_on": [{"task_key": "full_refresh_gold"}],
      "job_cluster_key": "full_refresh_cluster",
      "run_if": "ALL_SUCCESS"
    }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "full_refresh_cluster",
      "new_cluster": {
        "spark_version": "15.4.x-scala2.12",
        "node_type_id": "i3.2xlarge",
        "num_workers": 8,
        "spark_conf": {
          "spark.databricks.delta.preview.enabled": "true",
          "spark.sql.shuffle.partitions": "400"
        },
        "spark_env_vars": {
          "DBT_MATERIALIZATION": "table"
        },
        "custom_tags": {
          "project": "alo-lakehouse",
          "job-type": "full-refresh"
        }
      }
    }
  ]
}
